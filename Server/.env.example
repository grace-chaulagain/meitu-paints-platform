# Hostinger Business Web Hosting - managed Node.js app
NODE_ENV=production

# Hostinger provides PORT at runtime. Leave this blank in hPanel unless Hostinger asks for it.
PORT=

# Local development can use HOST=127.0.0.1.
# Most production platforms should leave HOST empty and bind with the platform default.
# Leave HOST empty on Hostinger so the managed runtime controls binding.
HOST=
TRUST_PROXY=true

MONGO_URI=mongodb+srv://USER:PASSWORD@HOST/DATABASE

JWT_ACCESS_SECRET=replace-with-long-random-secret
JWT_REFRESH_SECRET=replace-with-different-long-random-secret
ACCESS_TOKEN_EXPIRES_IN=10m
REFRESH_TOKEN_EXPIRES_IN=7d
REFRESH_TTL_DAYS=7

# Public website URL used by emails and notification deep links.
APP_URL=https://your-domain.com
API_URL=https://your-domain.com

# Recommended Hostinger shape: one Node app serves API + built frontend.
SERVE_CLIENT=true
CORS_ORIGIN=https://your-domain.com
CLIENT_DIST_DIR=

COOKIE_DOMAIN=
COOKIE_SAME_SITE=lax
COOKIE_SECURE=true

SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=notifications@example.com
SMTP_PASS=replace-with-smtp-password
MAIL_FROM="Meitu Paints <notifications@example.com>"
ADMIN_NOTIFICATION_EMAIL=admin@example.com

# Optional Google Sheets archive for every verified order.
# Create a Google Cloud service account, share the Sheet with its client email,
# then enable this integration.
GOOGLE_SHEETS_ORDER_ARCHIVE_ENABLED=false
GOOGLE_SHEETS_ORDER_ARCHIVE_SPREADSHEET_ID=
GOOGLE_SHEETS_ORDER_ARCHIVE_SHEET_NAME=Verified Orders

# Prefer GOOGLE_SERVICE_ACCOUNT_JSON_BASE64 on Hostinger to avoid newline issues.
# Example local encoding: base64 -i service-account.json
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=

# Alternative split-field configuration:
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

CLOUD_NAME=cloudinary-cloud-name
API_KEY=cloudinary-api-key
API_SECRET=cloudinary-api-secret
