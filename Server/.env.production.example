# Production backend environment template. Do not commit the real production file.
NODE_ENV=production
DB_ENV=production

PORT=
HOST=
TRUST_PROXY=true

# Must point to the live production database.
MONGO_URI=mongodb+srv://PRODUCTION_USER:PRODUCTION_PASSWORD@PRODUCTION_HOST/meitu_production

JWT_ACCESS_SECRET=replace-with-long-random-production-secret
JWT_REFRESH_SECRET=replace-with-different-long-random-production-secret
ACCESS_TOKEN_EXPIRES_IN=10m
REFRESH_TOKEN_EXPIRES_IN=7d
REFRESH_TTL_DAYS=7

FACTORY_EMAIL=factory@example.com
FACTORY_PASSWORD=replace-with-strong-production-factory-password

APP_URL=https://your-production-domain.com
API_URL=https://your-production-domain.com
SERVE_CLIENT=true
CORS_ORIGIN=https://your-production-domain.com
CLIENT_DIST_DIR=

COOKIE_DOMAIN=
COOKIE_SAME_SITE=lax
COOKIE_SECURE=true

SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=notifications@example.com
SMTP_PASS=replace-with-smtp-password
MAIL_FROM="Meitu Paints <notifications@example.com>"
ADMIN_NOTIFICATION_EMAIL=admin@example.com

GOOGLE_SHEETS_ORDER_ARCHIVE_ENABLED=false
GOOGLE_SHEETS_ORDER_ARCHIVE_SPREADSHEET_ID=
GOOGLE_SHEETS_ORDER_ARCHIVE_SHEET_NAME=Verified Orders
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

CLOUD_NAME=cloudinary-cloud-name
API_KEY=cloudinary-api-key
API_SECRET=cloudinary-api-secret

# Keep false except during a planned, backed-up production migration/write.
ALLOW_PRODUCTION_DB_WRITE=false
ALLOW_DESTRUCTIVE_SEED=false
