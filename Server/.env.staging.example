# Staging/test backend environment. Copy to Server/.env.staging and fill real secrets locally or in Hostinger staging env vars.
NODE_ENV=staging
DB_ENV=staging

PORT=5002
HOST=127.0.0.1
TRUST_PROXY=false

# Must point to a staging/test database, never the live production database.
MONGO_URI=mongodb+srv://STAGING_USER:STAGING_PASSWORD@STAGING_HOST/meitu_staging

JWT_ACCESS_SECRET=replace-with-staging-access-secret
JWT_REFRESH_SECRET=replace-with-staging-refresh-secret
ACCESS_TOKEN_EXPIRES_IN=10m
REFRESH_TOKEN_EXPIRES_IN=7d
REFRESH_TTL_DAYS=7

FACTORY_EMAIL=factory.staging@example.com
FACTORY_PASSWORD=replace-with-strong-staging-factory-password

# Local frontend defaults. For Hostinger staging, use https://test.your-domain.com.
APP_URL=http://localhost:5173
API_URL=http://localhost:5002
SERVE_CLIENT=false
CORS_ORIGIN=http://localhost:5173
CLIENT_DIST_DIR=

COOKIE_DOMAIN=
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false

SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
MAIL_FROM="Meitu Paints Staging <notifications@example.com>"
ADMIN_NOTIFICATION_EMAIL=

GOOGLE_SHEETS_ORDER_ARCHIVE_ENABLED=false
GOOGLE_SHEETS_ORDER_ARCHIVE_SPREADSHEET_ID=
GOOGLE_SHEETS_ORDER_ARCHIVE_SHEET_NAME=Verified Orders Staging
GOOGLE_SERVICE_ACCOUNT_JSON_BASE64=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

CLOUD_NAME=
API_KEY=
API_SECRET=

# Safety switches. Keep false for normal staging work.
ALLOW_PRODUCTION_DB_WRITE=false
ALLOW_DESTRUCTIVE_SEED=false
